{
    "openapi": "3.0.0",
    "info": {
        "title": "Messages REST API",
        "description": "REST API для управления сообщениями",
        "version": "1.0.0"
    },
    "servers": [
        {
            "url": "http://127.0.0.1:8080/api/v1.0",
            "description": "Local development server"
        }
    ],
    "paths": {
        "/health": {
            "get": {
                "tags": [
                    "Health"
                ],
                "summary": "Проверка работоспособности API",
                "operationId": "3a96214786a47e1db32364869a9afa97",
                "responses": {
                    "200": {
                        "description": "Сервис работает",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "status": {
                                            "type": "string",
                                            "example": "ok"
                                        },
                                        "service": {
                                            "type": "string",
                                            "example": "rest-api"
                                        },
                                        "version": {
                                            "type": "string",
                                            "example": "1.0"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/messages": {
            "get": {
                "tags": [
                    "Messages"
                ],
                "summary": "Получить список всех сообщений",
                "operationId": "e26f3220c2a75e55b14df917068435d3",
                "responses": {
                    "200": {
                        "description": "Успешный запрос",
                        "headers": {
                            "X-Total-Count": {
                                "description": "Общее количество сообщений",
                                "schema": {
                                    "type": "integer"
                                }
                            }
                        },
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "data": {
                                            "type": "array",
                                            "items": {
                                                "$ref": "#/components/schemas/Message"
                                            }
                                        },
                                        "meta": {
                                            "properties": {
                                                "count": {
                                                    "type": "integer"
                                                }
                                            },
                                            "type": "object"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                }
            },
            "post": {
                "tags": [
                    "Messages"
                ],
                "summary": "Создать новое сообщение",
                "operationId": "081de7448230192b302bce60a14646b9",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "content"
                                ],
                                "properties": {
                                    "content": {
                                        "description": "Текст сообщения",
                                        "type": "string"
                                    },
                                    "author": {
                                        "description": "Автор сообщения",
                                        "type": "string",
                                        "default": "anonymous"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Сообщение создано",
                        "headers": {
                            "Location": {
                                "description": "URL созданного ресурса",
                                "schema": {
                                    "type": "string"
                                }
                            }
                        },
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "data": {
                                            "$ref": "#/components/schemas/Message"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Ошибка валидации"
                    }
                }
            },
            "options": {
                "tags": [
                    "Messages"
                ],
                "summary": "Получить список доступных HTTP-методов для коллекции сообщений",
                "operationId": "b79b2172a15000299d3e642b9f30cc0a",
                "responses": {
                    "200": {
                        "description": "Список доступных методов",
                        "headers": {
                            "Allow": {
                                "description": "Список разрешённых HTTP-методов",
                                "schema": {
                                    "type": "string"
                                }
                            }
                        }
                    }
                }
            },
            "head": {
                "tags": [
                    "Messages"
                ],
                "summary": "Получить метаданные коллекции сообщений (без тела ответа)",
                "operationId": "3c6ad0926c3c905199b63c6f599d3e41",
                "responses": {
                    "200": {
                        "description": "Метаданные коллекции",
                        "headers": {
                            "X-Total-Count": {
                                "description": "Общее количество сообщений",
                                "schema": {
                                    "type": "integer"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/messages/{id}": {
            "get": {
                "tags": [
                    "Messages"
                ],
                "summary": "Получить сообщение по ID",
                "operationId": "832d665a95edfeb98eb786d78662c8dd",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Успешный запрос",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "data": {
                                            "$ref": "#/components/schemas/Message"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Сообщение не найдено"
                    }
                }
            },
            "put": {
                "tags": [
                    "Messages"
                ],
                "summary": "Полностью заменить сообщение",
                "operationId": "d2d3f3d487b2366b22f4626ca89e7f67",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "content"
                                ],
                                "properties": {
                                    "content": {
                                        "description": "Текст сообщения",
                                        "type": "string"
                                    },
                                    "author": {
                                        "description": "Автор сообщения",
                                        "type": "string"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Сообщение обновлено",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "data": {
                                            "$ref": "#/components/schemas/Message"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Сообщение не найдено"
                    },
                    "422": {
                        "description": "Ошибка валидации"
                    }
                }
            },
            "delete": {
                "tags": [
                    "Messages"
                ],
                "summary": "Удалить сообщение",
                "operationId": "4a20c03bfd74d619c2146b141788efd7",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "204": {
                        "description": "Сообщение удалено"
                    },
                    "404": {
                        "description": "Сообщение не найдено"
                    }
                }
            },
            "options": {
                "tags": [
                    "Messages"
                ],
                "summary": "Получить список доступных HTTP-методов для конкретного сообщения",
                "operationId": "fbd6bafe429096b7bc3db2dd4dec7895",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Список доступных методов",
                        "headers": {
                            "Allow": {
                                "description": "Список разрешённых HTTP-методов",
                                "schema": {
                                    "type": "string"
                                }
                            }
                        }
                    }
                }
            },
            "head": {
                "tags": [
                    "Messages"
                ],
                "summary": "Получить метаданные конкретного сообщения (без тела ответа)",
                "operationId": "2cd667c3091c5b2f9dad89e620e3efe9",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Метаданные сообщения",
                        "headers": {
                            "X-Resource-Id": {
                                "description": "ID сообщения",
                                "schema": {
                                    "type": "integer"
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Сообщение не найдено"
                    }
                }
            },
            "patch": {
                "tags": [
                    "Messages"
                ],
                "summary": "Частично обновить сообщение",
                "operationId": "2b2a267ddd5bf0922c202728e37da4bc",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "properties": {
                                    "content": {
                                        "description": "Текст сообщения",
                                        "type": "string"
                                    },
                                    "author": {
                                        "description": "Автор сообщения",
                                        "type": "string"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Сообщение обновлено",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "data": {
                                            "$ref": "#/components/schemas/Message"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Сообщение не найдено"
                    },
                    "422": {
                        "description": "Ошибка валидации"
                    }
                }
            }
        }
    },
    "components": {
        "schemas": {
            "Message": {
                "properties": {
                    "id": {
                        "type": "integer",
                        "example": 1
                    },
                    "content": {
                        "type": "string",
                        "example": "Hello World"
                    },
                    "author": {
                        "type": "string",
                        "example": "anonymous"
                    },
                    "createdAt": {
                        "type": "string",
                        "format": "date-time"
                    },
                    "updatedAt": {
                        "type": "string",
                        "format": "date-time"
                    }
                },
                "type": "object"
            }
        }
    },
    "tags": [
        {
            "name": "Health",
            "description": "Health"
        },
        {
            "name": "Messages",
            "description": "Messages"
        }
    ]
}