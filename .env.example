# OpenAPI Servers configuration
# Format: OPENAPI_SERVERS=json encoded array of server objects (wrapped in single quotes)
# Each server object must have "url" and optional "description" keys
#
# Examples:
# Single server:
OPENAPI_SERVERS='[{"url":"http://127.0.0.1:8080/api/v1.0","description":"Local development server"}]'
#
# Multiple servers:
# OPENAPI_SERVERS='[{"url":"http://127.0.0.1:8080/api/v1.0","description":"Local development server"},{"url":"https://api.example.com/api/v1.0","description":"Production server"}]'
#
# Docker environment:
# OPENAPI_SERVERS='[{"url":"http://nginx/api/v1.0","description":"Docker nginx server"}]'
